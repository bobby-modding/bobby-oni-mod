# This .gitignore file should be placed at the root of your Unity/Mod directory

# --- Unity Generated Files ---
/[Ll]ibrary/
/[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Memory dumps
*.dmp

# Crash dumps generated by Unity
sysinfo.txt

# Autogenerated VS/MonoDevelop/Rider files
[Ee]xported[Oo]bj/
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D Meta Files
# (Only un-ignore these if you are tracking assets to share with other modders)
[!*.meta]
/[Aa]ssets/[Ee]ditor Default Resources/

# --- Modding Specifics ---
# Ignore compiled release DLLs and build outputs
bin/
Release/
Debug/
*.dll

# Ignore local game installation paths or dependency folders
References/
libs/
*.manifest

# OS Generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Directory.Build.props.user
